# ===========================================
# Backy - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# Google OAuth Configuration
# -------------------------------------------
# Get these from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
#
# 1. Create a new OAuth 2.0 Client ID
# 2. Set Authorized JavaScript origins to your domain(s)
# 3. Set Authorized redirect URIs to:
#    - http://localhost:7026/api/auth/callback/google (development)
#    - https://your-domain.example.com/api/auth/callback/google (production)

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# -------------------------------------------
# NextAuth Configuration
# -------------------------------------------
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here

# Base URL for your application (used for OAuth callback URLs)
# REQUIRED in production — e.g. https://your-domain.example.com
# In development, set to http://localhost:7026
NEXTAUTH_URL=http://localhost:7026

# -------------------------------------------
# Access Control
# -------------------------------------------
# Comma-separated list of email addresses allowed to login
ALLOWED_EMAILS=your-email@gmail.com

# -------------------------------------------
# Reverse Proxy / Security Configuration
# -------------------------------------------
# Set to "true" if using HTTPS reverse proxy in development
USE_SECURE_COOKIES=false

# Comma-separated list of trusted Host header values for redirect URLs.
# Prevents open-redirect via x-forwarded-host spoofing.
# Default: localhost:7026
# ALLOWED_HOSTS=your-domain.example.com,localhost:7026

# -------------------------------------------
# Cloudflare R2 Configuration
# -------------------------------------------
# S3-compatible API credentials for file storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=backy

# -------------------------------------------
# Cloudflare D1 Configuration
# -------------------------------------------
# REST API credentials for metadata database
D1_ACCOUNT_ID=your-cloudflare-account-id
D1_DATABASE_ID=your-d1-database-id
D1_API_TOKEN=your-cloudflare-api-token

# -------------------------------------------
# Cron Auto-Backup Secret
# -------------------------------------------
# Shared secret between Cloudflare Worker and Backy for cron trigger auth
# Generate with: openssl rand -base64 32
CRON_SECRET=your-cron-secret-here

# -------------------------------------------
# SSRF Allowlist (Testing / Development Only)
# -------------------------------------------
# Comma-separated origins (protocol+host+port) that bypass SSRF webhook validation.
# Matching is done on parsed URL origin, not string prefix.
# Used for E2E tests where webhook targets are on localhost.
# NEVER set in production.
# SSRF_ALLOWLIST=http://localhost:17026

# -------------------------------------------
# Test Resource Overrides (.env.test)
# -------------------------------------------
# E2E tests use separate D1 + R2 to avoid corrupting production.
# Create a .env.test file with these overrides:
# D1_DATABASE_ID=your-test-d1-database-id
# R2_BUCKET_NAME=backy-test
